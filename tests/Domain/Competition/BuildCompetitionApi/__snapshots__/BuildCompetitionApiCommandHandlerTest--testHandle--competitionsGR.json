            "venue": {
                "name": "\"\u0399\u03c9\u03bd\u03af\u03b1\" \u03a0\u03bf\u03bb\u03b9\u03c4\u03b9\u03c3\u03c4\u03b9\u03ba\u03cc \u039a\u03ad\u03bd\u03c4\u03c1\u03bf \/ \"Ionia\" Caltural Center",
                "address": "\u039b\u03b5\u03c9\u03c6. \u039a\u03c9\u03bd\u03c3\u03c4\u03b1\u03bd\u03c4\u03af\u03bd\u03bf\u03c5 \u039a\u03b1\u03c1\u03b1\u03bc\u03b1\u03bd\u03bb\u03ae 113, \u0392\u03bf\u03cd\u03bb\u03b1 166 73",
                "details": "Culture Centre",
