{
  "name": "robiningelbrecht/wca-rest-api",
  "keywords": [
    "WCA",
    "Rest",
    "API"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Robin Ingelbrecht",
      "email": "ingelbrecht_robin@hotmail.com"
    }
  ],
  "require": {
    "php": "^8.5",
    "ext-intl": "*",
    "ext-json": "*",
    "ausi/slug-generator": "^1.1",
    "doctrine/dbal": "^3.6",
    "doctrine/orm": "^2.12",
    "lcobucci/clock": "^2.2",
    "league/flysystem": "^3.15",
    "php-di/php-di": "^7.0",
    "php-di/slim-bridge": "^3.3",
    "ramsey/uuid": "^4.7",
    "slim/psr7": "^1.6",
    "slim/slim": "^4.11",
    "symfony/cache": "^7.0",
    "symfony/console": "^7.0",
    "symfony/finder": "^7.0",
    "symfony/process": "^7.0",
    "thecodingmachine/safe": "^3.3",
    "twig/twig": "^3.4",
    "vlucas/phpdotenv": "^5.4"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.16",
    "nunomaduro/collision": "^8.0",
    "phpstan/phpstan": "^1.10",
    "phpunit/phpunit": "^11.0",
    "robiningelbrecht/phpunit-pretty-print": "^1.2.0",
    "spatie/phpunit-snapshot-assertions": "^5.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "post-create-project-cmd": [
      "cp ./.env.dist ./.env"
    ]
  }
}
